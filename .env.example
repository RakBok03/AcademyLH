NODE_ENV=production
PORT=3000
APP_URL=https://lofthallacademy.ru
POSTGRES_PASSWORD=change_me
DATABASE_URL=postgres://academylh:change_me@db:5432/academylh
SESSION_SECRET=change_me_long_random_string

# Production must require Telegram initData. Use 1 only for isolated local demos.
ALLOW_UNVERIFIED_TELEGRAM=0
TELEGRAM_BOT_TOKEN=
ADMIN_TELEGRAM_IDS=

# PuzzleBot integration. Use PuzzleBot Incoming API token, not BotFather token.
PUZZLEBOT_API_TOKEN=
PUZZLEBOT_REVIEW_CHAT_ID=
PUZZLEBOT_REWARD_COMMAND=

# NocoDB menu integration for task #2.
NOCODB_BASE_URL=https://nocodb.puzzlebot.top
NOCODB_TOKEN=
NOCODB_TABLE_ID=
NOCODB_TYPE_EVENT_FIELD=menu_category
NOCODB_CLASS_DISH_FIELD=dish_class
NOCODB_PHOTO_STATUS_FIELD=is_photo
NOCODB_PHOTO_STATUS_EMPTY_VALUE=0
NOCODB_DISH_NAME_FIELD=specific_dish
