{
  "name": "academylh",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm:dev:server\" \"npm:dev:client\"",
    "dev:server": "node --watch server/index.js",
    "dev:client": "vite --config client/vite.config.js",
    "build": "vite build --config client/vite.config.js",
    "start": "node server/index.js",
    "db:migrate": "node server/db/migrate.js",
    "db:seed": "node server/db/seed.js",
    "db:backfill:alcohol-description": "node scripts/backfill-alcohol-description.mjs",
    "db:backfill:quiz-series": "node scripts/backfill-quiz-series.mjs",
    "db:backfill:spaces-blocks": "node scripts/backfill-spaces-blocks.mjs",
    "extract:puzzlebot": "node scripts/extract-puzzlebot-data.mjs",
    "import:legacy-users": "node scripts/import-legacy-users.mjs"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "jsonwebtoken": "^9.0.2",
    "lucide-react": "^0.468.0",
    "multer": "^2.0.2",
    "pg": "^8.13.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.0",
    "vite": "^6.0.3"
  }
}
